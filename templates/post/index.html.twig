{% extends 'base.html.twig' %}

{% block title %}Feed{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto py-8 px-4">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-extrabold text-slate-800">Seu Feed</h1>
        <a href="{{ path('app_post_new') }}" class="btn btn-primary btn-sm text-white">Criar Post</a>
    </div>

    <div class="space-y-6">
        {% for post in posts %}
            <article class="card w-full bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                <div class="card-body p-5">
                    <h2 class="card-title text-xl font-bold text-slate-900">{{ post.title }}</h2>
                    <p class="text-slate-600 leading-relaxed">{{ post.content|slice(0, 150) }}{{ post.content|length > 150 ? '...' : '' }}</p>
                    
                    <div class="card-actions justify-between items-center mt-4">
                        <span class="text-xs text-slate-400 font-medium">
                            {{ post.createdAt ? post.createdAt|date('d M, Y') : '' }}
                        </span>
                        <div class="flex gap-2">
                            <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-ghost btn-xs">Ler mais</a>
                            <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-ghost btn-xs text-slate-400">Editar</a>
                        </div>
                    </div>
                </div>
            </article>
        {% else %}
            <div class="text-center py-20 text-slate-400">
                <p>Nenhum post por aqui. Que tal começar a escrever?</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}