{% extends 'base.html.twig' %}

{% block title %}Novo Post{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto pt-10">
    <div class="card bg-white shadow-lg border border-slate-200">
        <div class="card-body">
            <h1 class="text-2xl font-bold text-slate-800 mb-4">Criar Novo Post</h1>
            
            {{ include('post/_form.html.twig') }}

            <div class="mt-6 border-t pt-4">
                <a href="{{ path('app_post_index') }}" class="btn btn-ghost btn-sm text-slate-500">
                    ← Voltar para a lista
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}