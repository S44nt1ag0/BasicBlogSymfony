<!DOCTYPE html>
<html lang="pt-br" data-theme="light">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}DevBlog | Dashboard{% endblock %}</title>

        <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />
        <script src="https://cdn.tailwindcss.com"></script>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

        <style>
            body { font-family: 'Inter', sans-serif; }
        </style>
    </head>
    <body class="bg-slate-50 min-h-screen">
<nav class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md">
    <div class="max-w-5xl mx-auto navbar px-4 sm:px-6 lg:px-8">
        
        <div class="flex-1">
            <a href="{{ path('app_post_index') }}" class="flex items-center gap-2 group">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold shadow-lg shadow-primary/30 group-hover:scale-105 transition-transform">
                    B
                </div>
                <span class="text-xl font-black tracking-tight text-slate-800">Meu<span class="text-primary">Blog</span></span>
            </a>
        </div>
        <div class="flex-none gap-2">
            <ul class="menu menu-horizontal px-1 gap-1 items-center">
                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                    <li>
                        <a href="{{ path('app_post_index') }}" class="font-medium text-slate-600 hover:text-primary active:bg-slate-100 rounded-lg">
                            Feed
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_post_new') }}" class="btn btn-primary btn-sm text-white rounded-lg px-4 ml-2 shadow-sm">
                            + Novo Post
                        </a>
                    </li>
                    
                    <div class="dropdown dropdown-end ml-4">
                        <label tabindex="0" class="btn btn-ghost btn-circle avatar border border-slate-200 bg-slate-50">
                            <div class="w-10 rounded-full flex items-center justify-center">
                                <span class="text-xs font-bold text-slate-500">{{ app.user.userIdentifier|slice(0, 1)|upper }}</span>
                            </div>
                        </label>
                        <ul tabindex="0" class="mt-3 z-[1] p-2 shadow-xl menu menu-sm dropdown-content bg-white border border-slate-100 rounded-xl w-52">
                            <li class="menu-title text-slate-400">Minha Conta</li>
                            <li><a href="{{ path('app_logout') }}" class="text-error font-medium">Sair da conta</a></li>
                        </ul>
                    </div>

                {% else %}
                    <li>
                        <a href="{{ path('app_login') }}" class="font-medium text-slate-600 hover:text-primary">Entrar</a>
                    </li>
                    <li>
                        <a href="{{ path('app_register') }}" class="btn btn-ghost btn-sm border-slate-200 ml-2 rounded-lg">Cadastrar</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

        <main class="max-w-4xl mx-auto px-4">
            {% block body %}
                <div class="card bg-white shadow-sm border border-slate-200">
                    <div class="card-body">
                        <h2 class="card-title text-2xl text-slate-800">Seu primeiro post aparecerá aqui!</h2>
                        <p class="text-slate-600">O backend já está configurado, agora é só criar a entidade para salvar no banco.</p>
                        <div class="card-actions justify-end mt-4">
                            <button class="btn btn-outline btn-sm">Ler mais</button>
                        </div>
                    </div>
                </div>
            {% endblock %}
        </main>

        <footer class="footer footer-center p-10 text-slate-500 mt-20">
            <aside>
                <p class="font-bold">DevBlog Engineering</p> 
                <p>Copyright © 2026 - All right reserved</p>
            </aside>
        </footer>
    </body>
</html>